# ============================================
# AI Gateway Docker Compose 环境变量配置
# ============================================
# 复制此文件为 .env 并根据需要修改配置
# cp .env.example .env

# ============================================
# MySQL 配置
# ============================================
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=ai_gateway
MYSQL_USER=gateway
MYSQL_PASSWORD=gateway123
MYSQL_PORT=3306

# ============================================
# Redis 配置
# ============================================
REDIS_PORT=6379

# ============================================
# ClickHouse 配置
# ============================================
CLICKHOUSE_DB=ai_gateway
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# ============================================
# 后端服务配置
# ============================================
BACKEND_PORT=8080

# ============================================
# 前端服务配置
# ============================================
FRONTEND_PORT=80

# ============================================
# Nginx 配置（可选）
# ============================================
NGINX_PORT=8000
